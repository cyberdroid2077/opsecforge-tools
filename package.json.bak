{
  "name": "jwt-decoder",
  "version": "1.8.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --pretty",
    "audit": "npm audit --audit-level=high",
    "health": "node scripts/monitor/health-check.js"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@vercel/analytics": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "crypto-js": "^4.2.0",
    "diff": "^8.0.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "next-pwa": "^5.6.0",
    "nodemailer": "^8.0.2",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
